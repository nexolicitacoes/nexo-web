SERVER_URL=http://localhost:8080

# Chave Global da Evolution API para acesso (troque se for colocar em produção)
AUTHENTICATION_GLOBAL_AUTH_TOKEN=GlobalToken12345

# PostgreSQL
POSTGRES_USER=evouser
POSTGRES_PASSWORD=evopassword123
POSTGRES_DB=evolution

# Redis
REDIS_HOST=evolution_redis
REDIS_PORT=6379

# Configurações Adicionais da API
AUTHENTICATION_API_KEY_ACCOUNTS=true
EXPOSE_IN_LOCALHOST=true
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evouser:evopassword123@evolution_postgres:5432/evolution

# Evolution Manager
Evolution_Manager_PORT=3000
